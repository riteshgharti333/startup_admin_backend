{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]  // ← Add this line
  },
  "include": ["src/**/*", "prisma.config.ts"],  // ← Add prisma.config.ts
  "exclude": ["node_modules", "dist"]
}